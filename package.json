{
    "name": "melta",
    "version": "1.0.1",
    "description": "",
    "private": true,
    "packageManager": "pnpm@9.15.0",
    "pnpm": {
        "overrides": {
            "@syncfusion/ej2-base": "github:MeltaTeam/not-stolen-base"
        }
    },
    "scripts": {
        "build": "turbo run build --concurrency=4",
        "build:packages": "turbo run build --filter='./packages/*' --concurrency=4",
        "build:services": "turbo run build --filter='*-service' --concurrency=4",
        "typecheck": "turbo run typecheck --filter='*-service' --continue",
        "dev": "turbo run dev",
        "test": "turbo run test",
        "biome": "biome check .",
        "biome:fix": "biome check --write .",
        "clean": "turbo run clean && rimraf ./**/dist",
        "clean:all": "rimraf ./**/dist ./**/node_modules ./node_modules",
        "clean:cache": "rimraf .turbo/cache",
        "clean:cache:check": "du -sh .turbo/cache 2>/dev/null || echo 'Cache is empty'",
        "start-ui": "turbo run start:docker --filter=frontend-service",
        "pre-push": "pnpm run biome && turbo run build"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/melta-team/melta.git"
    },
    "author": "",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/melta-team/melta/issues"
    },
    "homepage": "https://github.com/melta-team/melta#readme",
    "devDependencies": {
        "@biomejs/biome": "^2.3.13",
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.1",
        "@types/amqplib": "^0.10.8",
        "@types/express": "^5.0.0",
        "@types/jest": "^30.0.0",
        "@types/mongoose": "^5.11.97",
        "@types/node": "^24.3.0",
        "husky": "^9.1.7",
        "jest": "^30.0.5",
        "rimraf": "^6.0.1",
        "ts-jest": "^29.4.1",
        "ts-node": "^10.9.2",
        "tsup": "^8.5.1",
        "turbo": "^2.6.1",
        "typescript": "^5.9.2"
    },
    "dependencies": {
        "@nestjs/common": "^11.0.1",
        "@nestjs/config": "^4.0.0",
        "@nestjs/core": "^11.0.1",
        "@nestjs/microservices": "^11.1.11",
        "@nestjs/mongoose": "^11.0.4",
        "@nestjs/platform-express": "^11.0.1",
        "@nestjs/swagger": "^11.2.3",
        "@nestjs/terminus": "^11.0.0",
        "@nestjs/throttler": "^6.5.0",
        "axios": "^1.11.0",
        "dotenv": "^17.2.1",
        "elastic-apm-node": "^4.13.0",
        "env-var": "^7.5.0",
        "express": "^4.19.2",
        "helmet": "^8.1.0",
        "http-status-codes": "^2.3.0",
        "joi": "^18.0.1",
        "mongoose": "^8.17.2",
        "morgan": "^1.10.1",
        "nest-winston": "^1.10.2",
        "nestjs-cls": "^6.2.0",
        "nestjs-zod": "^5.1.1",
        "nodemon": "^3.1.0",
        "rxjs": "^7.8.2",
        "uuid": "^11.1.0",
        "winston": "^3.17.0",
        "winston-daily-rotate-file": "^5.0.0",
        "zod": "^4.3.6"
    }
}
