{
    "name": "melta",
    "version": "1.0.1",
    "description": "",
    "private": true,
    "packageManager": "npm@10.9.0",
    "workspaces": [
        "activity-log-service",
        "cron-service",
        "dashboard-service",
        "frontend-service",
        "gantt-service",
        "gateway-service",
        "global-search-service",
        "instance-service",
        "notification-service",
        "preview-service",
        "process-service",
        "rule-breach-service",
        "semantic-service",
        "storage-service",
        "template-service",
        "user-service",
        "workspace-service",
        "mock-service",
        "packages/*"
    ],
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "test": "turbo run test",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "clean": "turbo run clean && rimraf ./**/dist",
        "clean:all": "rimraf ./**/dist ./**/node_modules ./node_modules ./**/package-lock.json ./package-lock.json",
        "clean:cache": "rimraf .turbo/cache",
        "clean:cache:check": "du -sh .turbo/cache 2>/dev/null || echo 'Cache is empty'",
        "start-ui": "turbo run start:docker --filter=frontend-service",
        "pre-push": "npm run lint && turbo run build",
        "migrate": "npm run clean:all && npm install && turbo run build --filter=shared && npm run start-ui"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/melta-team/melta.git"
    },
    "author": "",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/melta-team/melta/issues"
    },
    "homepage": "https://github.com/melta-team/melta#readme",
    "devDependencies": {
        "@biomejs/biome": "2.1.2",
        "@types/jest": "^30.0.0",
        "@types/mongoose": "^5.11.97",
        "@types/node": "^24.3.0",
        "husky": "^9.1.7",
        "jest": "^30.0.5",
        "rimraf": "^6.0.1",
        "ts-jest": "^29.4.1",
        "turbo": "^2.6.1",
        "typescript": "^5.9.2"
    },
    "dependencies": {
        "axios": "^1.11.0",
        "dotenv": "^17.2.1",
        "elastic-apm-node": "^4.13.0",
        "env-var": "^7.5.0",
        "express": "^4.19.2",
        "helmet": "^8.1.0",
        "http-status-codes": "^2.3.0",
        "joi": "^18.0.1",
        "mongoose": "^8.17.2",
        "morgan": "^1.10.1",
        "uuid": "^11.1.0",
        "winston": "^3.17.0",
        "winston-daily-rotate-file": "^5.0.0"
    }
}
