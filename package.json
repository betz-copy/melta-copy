{
    "name": "melta",
    "version": "1.0.1",
    "description": "",
    "private": true,
    "packageManager": "pnpm@9.15.0",
    "scripts": {
        "build": "turbo run build --concurrency=4",
        "build:packages": "turbo run build --filter='./packages/*' --concurrency=4",
        "build:services": "turbo run build --filter='*-service' --concurrency=4",
        "typecheck": "turbo run typecheck --filter='*-service' --continue",
        "dev": "turbo run dev",
        "test": "turbo run test",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "clean": "turbo run clean && rimraf ./**/dist",
        "clean:all": "rimraf ./**/dist ./**/node_modules ./node_modules pnpm-lock.yaml",
        "clean:cache": "rimraf .turbo/cache",
        "clean:cache:check": "du -sh .turbo/cache 2>/dev/null || echo 'Cache is empty'",
        "start-ui": "turbo run start:docker --filter=frontend-service",
        "pre-push": "pnpm run lint && turbo run build",
        "migrate": "pnpm run clean:all && pnpm install && turbo run build --filter=shared && pnpm run start-ui"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/melta-team/melta.git"
    },
    "author": "",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/melta-team/melta/issues"
    },
    "homepage": "https://github.com/melta-team/melta#readme",
    "pnpm": {
        "auto-install-peers": true,
        "strict-peer-dependencies": false,
        "shamefully-hoist": false,
        "node-linker": "isolated"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.1.2",
        "@types/jest": "^30.0.0",
        "@types/mongoose": "^5.11.97",
        "@types/node": "^24.3.0",
        "cross-env": "^10.1.0",
        "husky": "^9.1.7",
        "jest": "^30.0.5",
        "rimraf": "^6.0.1",
        "ts-jest": "^29.4.1",
        "tsup": "^8.5.1",
        "turbo": "^2.6.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.2"
    },
    "dependencies": {
        "axios": "^1.11.0",
        "dotenv": "^17.2.1",
        "elastic-apm-node": "^4.13.0",
        "env-var": "^7.5.0",
        "express": "^4.19.2",
        "helmet": "^8.1.0",
        "http-status-codes": "^2.3.0",
        "joi": "^18.0.1",
        "mongoose": "^8.17.2",
        "morgan": "^1.10.1",
        "nodemon": "^3.1.0",
        "uuid": "^11.1.0",
        "winston": "^3.17.0",
        "winston-daily-rotate-file": "^5.0.0"
    }
}
