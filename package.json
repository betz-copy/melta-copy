{
    "name": "melta",
    "version": "1.0.1",
    "description": "",
    "private": true,
    "workspaces": [
        "activity-log-service",
        "cron-service",
        "dashboard-service",
        "gantt-service",
        "gateway-service",
        "global-search-service",
        "instance-service",
        "notification-service",
        "preview-service",
        "process-service",
        "rule-breach-service",
        "semantic-service",
        "shared",
        "storage-service",
        "template-service",
        "user-service",
        "workspace-service",
        "mock-service"
    ],
    "scripts": {
        "test": "jest --coverage",
        "pre-push": "npm run lint && npm run build",
        "build": "npm run build --workspaces --if-present",
        "lint": "npm run lint --workspaces --if-present",
        "prettier": "npm run prettier --workspaces --if-present",
        "clean": "rimraf ./**/dist",
        "clean:all": "rimraf ./**/dist ./**/node_modules ./node_modules ./**/package-lock.json ./package-lock.json",
        "start-ui": "npm run -w frontend-service start:docker",
        "migrate": "npm run clean:all && npm install && npm run build -w shared && npm run start-ui"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/melta-team/melta.git"
    },
    "author": "",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/melta-team/melta/issues"
    },
    "homepage": "https://github.com/melta-team/melta#readme",
    "devDependencies": {
        "@types/jest": "^29.5.12",
        "@types/node": "^22.3.0",
        "@typescript-eslint/eslint-plugin": "^8.1.0",
        "@typescript-eslint/parser": "^8.1.0",
        "eslint": "^8.2.0",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-import": "^2.29.1",
        "eslint-plugin-prettier": "^5.2.1",
        "husky": "^6.0.0",
        "jest": "^29.7.0",
        "prettier": "^3.3.3",
        "rimraf": "^6.0.1",
        "ts-jest": "^29.2.4",
        "typescript": "^5.5.4"
    },
    "dependencies": {
        "axios": "^1.7.7",
        "dotenv": "^16.4.5",
        "elastic-apm-node": "^4.7.3",
        "env-var": "^7.5.0",
        "express": "^4.19.2",
        "helmet": "^7.1.0",
        "http-status-codes": "^2.3.0",
        "joi": "^17.13.3",
        "morgan": "^1.10.0",
        "uuid": "^10.0.0",
        "winston": "^3.14.1",
        "winston-daily-rotate-file": "^5.0.0"
    }
}
