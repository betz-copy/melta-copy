{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "allowJs": false,
    "sourceMap": true,
    "removeComments": true,
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictPropertyInitialization": false,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "outDir": "./dist/",
    "lib": ["ES2020.Promise"],
    "paths": {
      "@microservices/*": ["./services/*/src"]
    }
  },
  "include": ["src/**/*"]
}
