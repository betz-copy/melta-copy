{
    "name": "template-service",
    "version": "1.0.0",
    "description": "",
    "main": "",
    "scripts": {
        "start": "node --async-stack-traces ./dist/index.js",
        "dev": "pnpm build && pnpm start",
        "dev:nodemon": "nodemon --delay 3 --watch 'src/**/*.ts' --exec 'ts-node' src/index.ts",
        "test": "jest --coverage",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "build": "tsc",
        "build:watch": "tsc --watch",
        "clean": "rimraf dist"
    },
    "author": "Alexander Gurevich",
    "license": "ISC",
    "dependencies": {
        "@packages/category": "workspace:*",
        "@packages/child-template": "workspace:*",
        "@packages/common": "workspace:*",
        "@packages/entity": "workspace:*",
        "@packages/entity-template": "workspace:*",
        "@packages/global-search": "workspace:*",
        "@packages/map": "workspace:*",
        "@packages/printing-template": "workspace:*",
        "@packages/relationship-template": "workspace:*",
        "@packages/rule": "workspace:*",
        "@packages/utils": "workspace:*",
        "@packages/workspace": "workspace:*",
        "ajv": "^8.17.1",
        "ajv-formats": "^3.0.1",
        "date-fns": "^3.6.0",
        "flat": "^6.0.1",
        "lodash": "^4.17.21",
        "menashmq": "^0.1.6",
        "typescript-actions": "^1.1.1"
    },
    "devDependencies": {
        "@types/lodash": "^4.17.20",
        "@types/supertest": "^6.0.2",
        "supertest": "^7.0.0",
        "typescript": "^5.9.3"
    }
}
