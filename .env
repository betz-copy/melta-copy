# COMPOSE_PARALLEL_LIMIT=4

# Shared
NODE_ENV=developement
ENTITY_TEMPLATE_SERVICE_URL=http://entity-template-service:8000
RELATIONSHIP_TEMPLATE_SERVICE_URL=http://relationship-template-service:8000
INSTANCE_SERVICE_URL=http://instance-service:8000
STORAGE_SERVICE_URL=http://storage-service:8000
PERMISSION_SERVICE_URL=http://permission-service:8000
ACTIVITY_LOG_SERVICE_URL=http://activity-log-service:8000
NOTIFICATION_SERVICE_URL=http://notification-service:8000
RULE_BREACH_SERVICE_URL=http://rule-breach-service:8000
PROCESS_SERVICE_URL=http://process-service:8000
GANTT_SERVICE_URL=http://gantt-service:8000
PREVIEW_SERVICE_URL=http://preview-service:8000
KARTOFFEL_BASE_URL=https://kartoffel.branch-yesodot.org
STORAGE_SERVICE_UPLOAD_FILE_ROUTE=api/files
STORAGE_SERVICE_DOWNLOAD_FILE_ROUTE=api/files
STORAGE_SERVICE_DELETE_FILE_ROUTE=api/files
STORAGE_SERVICE_FILE_HYPER_LINK=http://localhost/api/files
RABBIT_URL=amqp://rabbit
MAX_FILE_BYTE_SIZE=150000000
MAX_REQUEST_BYTE_SIZE=1000000000

# Entity Template Service
ENTITY_TEMPLATE_SERVICE_MONGO_URL=mongodb://mongo/entity-template-service?replicaSet=rs0
MONGO_ENTITY_TEMPLATES_COLLECTION_NAME=entity-templates
MONGO_CATEGORIES_COLLECTION_NAME=categories

# Relationship Template Service
RELATIONSHIP_TEMPLATE_SERVICE_MONGO_URL=mongodb://mongo/relationship-template-service?replicaSet=rs0
MONGO_RELATIONSHIP_TEMPLATES_COLLECTION_NAME=relationship-templates
MONGO_RULES_COLLECTION_NAME=rules

# Storage Service
MINIO_ENDPOINT=minio
MINIO_BUCKET_NAME=files
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Activity Log Service
ACTIVITY_LOG_SERVICE_MONGO_URL=mongodb://mongo/activity-log-service?replicaSet=rs0
ACTIVITIES_COLLECTION_NAME=activities

# Gantt Service
GANTT_SERVICE_MONGO_URL=mongodb://mongo/gantt-service?replicaSet=rs0
MONGO_GANTTS_COLLECTION_NAME=gantts

# Gateway Service
TOKEN_SECRET=secret
SHRAGA_URL=https://shraga.shraga.branch-yesodot.org
CALLBACK_URL=http://localhost/api/auth/callback
ACCESS_TOKEN_NAME=rabaz-access-token
SYSTEM_UNAVAILABLE_URL=/unavailable
BASIC_AUTHENTICATION_USERS=[{"userId": "5e5688324203fc40043591aa", "password": "noamisgod"}]

# Permission Service
PERMISSION_SERVICE_MONGO_URL=mongodb://mongo/permission-service?replicaSet=rs0

# Instance Service
NEO4J_URL=neo4j://neo4j
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=test
NEO4J_DATABASE=neo4j
REDIS_HOST=redis://redis:6379

# Notification Service
NOTIFICATION_SERVICE_MONGO_URL=mongodb://mongo/notification-service?replicaSet=rs0
MONGO_NOTIFICATIONS_COLLECTION_NAME=notifications

# Rule Breach Service
RULE_BREACH_SERVICE_MONGO_URL=mongodb://mongo/rule-breach-service?replicaSet=rs0
MONGO_RULE_BREACH_ALERTS_COLLECTION_NAME=rule-breach-alerts
MONGO_RULE_BREACH_REQUESTS_COLLECTION_NAME=rule-breach-requests

# Process Service
PROCESS_SERVICE_MONGO_URL=mongodb://mongo/process-service?replicaSet=rs0
MONGO_PROCESS_TEMPLATES_COLLECTION_NAME=process-templates
MONGO_PROCESS_INSTANCES_COLLECTION_NAME=process-instances
MONGO_STEP_TEMPLATES_COLLECTION_NAME=step-templates
MONGO_STEP_INSTANCES_COLLECTION_NAME=step-instances

