
# Shared
NODE_ENV=developement
ENTITY_TEMPLATE_MANAGER_URI=http://entity-template-manager:8000
RELATIONSHIP_TEMPLATE_MANAGER_URI=http://relationship-template-manager:8000
INSTANCE_MANAGER_URI=http://instance-manager:8000
STORAGE_SERVICE_URI=http://storage-service:8000
PERMISSION_API_URL=http://permission-api:8000
ACTIVITY_LOG_URI=http://activity-log:8000
NOTIFICATION_SERVICE_URI=http://notification-service:8000
RULE_BREACH_SERVICE_URI=http://rule-breach-service:8000
PROCESS_SERVICE_URI=http://process-service:8000
GANTTS_SERVICE_URI=http://gantts-service:8000
KARTOFFEL_BASE_URL=https://kartoffel.branch-yesodot.org
STORAGE_SERVICE_UPLOAD_FILE_ROUTE=api/files
STORAGE_SERVICE_DOWNLOAD_FILE_ROUTE=api/files
STORAGE_SERVICE_DELETE_FILE_ROUTE=api/files
STORAGE_SERVICE_FILE_HYPER_LINK=http://jaws.branch-yesodot.org/api/files
RABBIT_URI=amqp://rabbit

# Entity Template Manager
ENTITY_TEMPLATE_MANAGER_MONGO_URI=mongodb://mongo/entity-manager?replicaSet=rs0
MONGO_ENTITY_TEMPLATE_COLLECTION_NAME=entity-templates
MONGO_CATEGORY_COLLECTION_NAME=categories

# Relationship Template Manager
RELATIONSHIP_TEMPLATE_MANAGER_MONGO_URI=mongodb://mongo/relationship-manager?replicaSet=rs0
MONGO_RELATIONSHIP_TEMPLATE_COLLECTION_NAME=relationship-templates
MONGO_RULE_COLLECTION_NAME=rules

# Storage Service
MINIO_ENDPOINT=minio
MINIO_BUCKET_NAME=files
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Activity Log
ACTIVITY_LOG_MONGO_URI=mongodb://mongo/activities?replicaSet=rs0
ACTIVITY_LOG_COLLECTION_NAME=activities

# Gantts Service
GANTTS_SERVICE_MONGO_URI=mongodb://mongo/gantts
GANTTS_SERVICE_MONGO_GANTTS_COLLECTION_NAME=gantts

# Backend
TOKEN_SECRET=secret
SHRAGA_URL=https://shraga.shraga.branch-yesodot.org
CALLBACK_URL=http://localhost/api/auth/callback
ACCESS_TOKEN_NAME=rabaz-access-token
SYSTEM_UNAVAILABLE_URL=/unavailable
BASIC_AUTHENTICATION_USERS=[]

# Permission api
PERMISSION_API_MONGO_URI=mongodb://mongo/permission-api?replicaSet=rs0

# Instance Manager
NEO4J_URL=neo4j://neo4j
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=test
NEO4J_DATABASE=neo4j
REDIS_HOST=redis://redis:6379

# Notification Service
NOTIFICATION_SERVICE_MONGO_URI=mongodb://mongo/notifications?replicaSet=rs0
NOTIFICATION_SERVICE_COLLECTION_NAME=notifications

# Rule Breach Service
RULE_BREACH_SERVICE_MONGO_URI=mongodb://mongo/rule-breaches?replicaSet=rs0
MONGO_RULE_BREACH_ALERTS_COLLECTION_NAME=rule-breach-alerts
MONGO_RULE_BREACH_REQUESTS_COLLECTION_NAME=rule-breach-requests

# Process Service
PROCESS_SERVICE_MONGO_URI=mongodb://mongo/process-service?replicaSet=rs0
MONGO_PROCESS_TEMPLATE_COLLECTION_NAME=process-templates
MONGO_PROCESS_INSTANCE_COLLECTION_NAME=process-instances
MONGO_STEP_TEMPLATE_COLLECTION_NAME=step-templates
MONGO_STEP_INSTANCE_COLLECTION_NAME=step-instances

