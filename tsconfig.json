{
    "compilerOptions": {
        "target": "ES2019",
        "module": "commonjs",
        "allowJs": false,
        "sourceMap": true,
        "removeComments": true,
        "strict": true,
        "noImplicitAny": false,
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "strictPropertyInitialization": false,
        "noImplicitThis": true,
        "alwaysStrict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "forceConsistentCasingInFileNames": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "./dist/",
        "lib": ["ES2020.Promise"],
        "paths": {
            "@microservices/*": ["./services/*/src"]
        }
    }
}