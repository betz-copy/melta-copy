# OpenAI / Local LLM Configuration

# 1. For OpenAI Official API:
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# 2. For Local Ollama (e.g. running Qwen 2.5):
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama  # (Often ignored but required by SDK)
# OPENAI_MODEL=qwen2.5:3b

# 3. For LM Studio:
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_API_KEY=lm-studio
# OPENAI_MODEL=local-model

# Active Configuration (Example for Ollama)
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=qwen2.5:7b

# Server port
PORT=3000
