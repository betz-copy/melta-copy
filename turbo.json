{
    "$schema": "https://turbo.build/schema.json",
    "globalEnv": ["NODE_ENV"],
    "ui": "stream",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", "build/**"],
            "cache": true,
            "env": ["NODE_ENV"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "start": {
            "cache": false,
            "persistent": true
        },
        "start:docker": {
            "cache": false,
            "persistent": true
        },
        "test": {
            "outputs": ["coverage/**"],
            "cache": true
        },
        "lint": {
            "cache": true
        },
        "clean": {
            "cache": false
        }
    }
}
